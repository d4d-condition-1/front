# ─────────────────────────────────────────────────────────────
# 이 파일을 `.env` 로 복사해서 서버에 두세요. `.env` 는 git에 올라가지 않습니다.
# 앱 컨테이너와 배포 웹훅 서버가 이 한 파일을 공유합니다.
#   cp .env.example .env   # 후 값 채우기
# ─────────────────────────────────────────────────────────────

# ── 앱(front) ──
# 프론트 노출 포트 (deploy.sh 가 이 값으로 컨테이너를 띄움)
APP_PORT=9555
# NEXT_PUBLIC_* 은 브라우저에 노출됨
NEXT_PUBLIC_SITE_URL=http://localhost:9555
# 백엔드 API 주소 (d4d-server). NEXT_PUBLIC_* 은 빌드 시점에 번들에 새겨지므로
# 배포 서버의 .env 에 실제 주소를 넣어야 한다. 예: http://<서버주소>:9666
NEXT_PUBLIC_API_BASE_URL=http://localhost:9666

# ── 서버 전용 시크릿 (예시 — 필요 시 추가) ──
# API_BASE_URL=
# DATABASE_URL=

# ── 배포 웹훅 서버 (deploy/webhook-server.js) ──
# 웹훅 수신 포트
WEBHOOK_PORT=9444
# GitHub Webhook 의 Secret 과 반드시 동일하게. 긴 랜덤 문자열 권장:
#   openssl rand -hex 32
WEBHOOK_SECRET=change-me-to-a-long-random-string
DEPLOY_BRANCH=main
